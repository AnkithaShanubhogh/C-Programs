#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main()
{
    int a=10 , b=4;
    float c=4.0,d=2.0;
    
    scanf("%d%d",&a,&b);
    int sum1 = a + b;
    int diff1 = a - b;
    
    scanf("%f %f", &c,&d);
    float sum2= c+d;
    float diff2 = c-d;
    
    printf("%d %d\n",sum1,diff1);
    printf("%.1f %.1f\n",sum2,diff2);
    
    return 0;
}
